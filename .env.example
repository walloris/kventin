# URL страницы для тестирования (обязательно)
START_URL=https://example.com

# --- Провайдер LLM: gigachat | jan | openai | anthropic | ollama ---
# LLM_PROVIDER=jan
# JAN_API_URL=http://127.0.0.1:1337
# JAN_API_KEY=jan-api-key
# JAN_MODEL=llama-3.2-11b-vision-instruct
# OpenAI (vision: gpt-4o-mini)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Ollama (локально)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llava

# GigaChat (Keycloak + gateway Sberbank HR)
# Стенд: dev или ift (выбирает token_url и api_url)
GIGACHAT_ENV=ift
# Логин/пароль Keycloak и client_id (обязательно для получения токена)
GIGACHAT_USERNAME=your_username
GIGACHAT_PASSWORD=your_password
GIGACHAT_CLIENT_ID=fakeuser
# Person ID для заголовка x-hrp-person-id (по одному на стенд)
# GIGACHAT_PERSON_ID_DEV=4c36eb04-0920-4449-9e07-ca4a68f80eef
# GIGACHAT_PERSON_ID_IFT=91ed8888-bff4-4d61-a72d-310db2eeaa37
# URL токена и API (дефолты — hr-dev/hr-ift.sberbank.ru, можно переопределить)
# GIGACHAT_TOKEN_URL_DEV=https://hr-dev.sberbank.ru/auth/realms/PAOSberbank/protocol/openid-connect/token
# GIGACHAT_TOKEN_URL_IFT=https://hr-ift.sberbank.ru/auth/realms/PAOSberbank/protocol/openid-connect/token
# GIGACHAT_API_URL_DEV=https://hr-dev.sberbank.ru/api-web/neurosearchbar/api/v1/gigachat/completion
# GIGACHAT_API_URL_IFT=https://hr-ift.sberbank.ru/api-web/neurosearchbar/api/v1/gigachat/completion
# Модель
GIGACHAT_MODEL=GigaChat-2-Max
# Опционально: готовый Bearer-токен (если не используешь username/password)
# GIGACHAT_TOKEN_HEADER=Bearer eyJ...

# Jira (для создания дефектов). Логин: username или email
JIRA_URL=https://your-company.atlassian.net
JIRA_USERNAME=your_username
# JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PROJ

# Движок браузера Playwright: chromium | firefox | webkit
# BROWSER_ENGINE=chromium
# Размер окна браузера (по умолчанию Full HD — на весь экран)
# VIEWPORT_WIDTH=1920
# VIEWPORT_HEIGHT=1080

# Опционально: замедление браузера (мс), чтобы видеть действия
BROWSER_SLOW_MO=300
# Пауза после подсветки элемента (мс)
HIGHLIGHT_DURATION_MS=800
# Чеклист: пауза между шагами (мс) — агент идёт медленнее по пунктам
CHECKLIST_STEP_DELAY_MS=2000
# Ожидание загрузки: таймаут networkidle (мс)
WAIT_NETWORK_IDLE_MS=5000

# --- Качество тестирования ---
# Тест-план в начале сессии по скриншоту (true/false)
ENABLE_TEST_PLAN_START=true
# Оракул после действий: достигнут ли ожидаемый результат (true/false)
ENABLE_ORACLE_AFTER_ACTION=true
# Второй проход перед дефектом: «это точно баг?» — меньше ложных тикетов (true/false)
ENABLE_SECOND_PASS_BUG=true
# Повторы при сбое действия (0 = без повторов, 1–3 рекомендуется)
ACTION_RETRY_COUNT=2
# Печатать отчёт сессии каждые N шагов (0 = только при дефектах)
SESSION_REPORT_EVERY_N=0
# Таймаут ответа GigaChat (сек): если не ответил — берётся fast action (0 = без лимита)
# GIGACHAT_RESPONSE_TIMEOUT_SEC=20
# Таймаут одного действия Playwright (клик, fill), мс
# ACTION_TIMEOUT_MS=10000
# Путь к файлу итогового отчёта сессии (пусто = только в консоль)
# SESSION_REPORT_PATH=./session_report.txt
# Красивый HTML-отчёт (создаётся папка screenshots рядом с файлом для скриншотов шагов)
# SESSION_REPORT_HTML_PATH=./session_report.html
# JSONL-лог шагов (одна строка JSON на шаг)
# SESSION_REPORT_JSONL=./session_steps.jsonl
# Папка для скриншотов каждого шага (если не задан SESSION_REPORT_HTML_PATH)
# SAVE_STEP_SCREENSHOTS_DIR=./kventin_steps
# Оракул только при изменении экрана или новых ошибках (true = меньше вызовов GigaChat)
# ORACLE_ON_VISUAL_OR_ERROR=true
# Критический сценарий: приоритетные шаги через запятую
# CRITICAL_FLOW_STEPS=Открыть меню, Клик Контакты, Заполнить форму
# Кнопки баннера cookies/согласия (текст через запятую)
# COOKIE_BANNER_BUTTON_TEXTS=Принять,Accept,Согласен,ОК,Понятно,Cookies
# CI/CD: в CI/GITHUB_ACTIONS/GITLAB_CI по умолчанию headless. Exit 1 если дефектов > N (0 = при любом, -1 = не падать)
# FAIL_ON_DEFECTS=-1
# Оверлеи, которые НЕ часть приложения (чат, поддержка): не тестируем. Паттерны в id/class/тексте через запятую.
# OVERLAY_IGNORE_PATTERNS=chat,чат,support,поддержк,jivo,intercom,crisp,drift,консультант

# --- Дополнительные фичи ---
# Visual regression: папка с baseline-скриншотами (первый прогон сохраняет, следующие сравнивают)
# VISUAL_BASELINE_DIR=./visual_baseline
# VISUAL_REGRESSION_THRESHOLD_PCT=5.0
# Экспорт сессии в Playwright .py скрипт
# PLAYWRIGHT_EXPORT_PATH=./session_script.py
# Сбор XHR/fetch в отчёт (true/false)
# ENABLE_API_INTERCEPT=true
# API_LOG_MAX=100
# Flakiness: повторных прогонов при сбое (0 = выкл, 2–5 типично)
# FLAKINESS_RERUN_COUNT=0
# Спецификация теста YAML (сценарии до автономного прохода)
# TEST_SPEC_YAML_PATH=./test_spec.yaml
# Несколько стартовых URL через запятую (приоритет над START_URL)
# START_URLS=https://example.com/page1,https://example.com/page2
# DOM diff после клика: детекция мёртвого клика (true/false)
# ENABLE_DOM_DIFF_AFTER_ACTION=true
# Утверждения на естественном языке (проверка через LLM после шагов), через запятую
# NL_ASSERTIONS=После логина видна фамилия пользователя
